{
  "name": "syntaur-app",
  "productName": "Syntaur",
  "version": "0.6.0",
  "description": "Syntaur Desktop - Mission workflow dashboard",
  "main": ".vite/build/main.js",
  "scripts": {
    "sync:syntaur-dashboard": "node ./scripts/sync-syntaur-dashboard.mjs",
    "prestart": "npm run sync:syntaur-dashboard",
    "start": "electron-forge start",
    "prepackage": "npm run sync:syntaur-dashboard",
    "package": "electron-forge package",
    "premake": "npm run sync:syntaur-dashboard",
    "make": "electron-forge make",
    "prepublish": "npm run sync:syntaur-dashboard",
    "publish": "electron-forge publish",
    "lint": "tsc --noEmit",
    "postinstall": "npm run sync:syntaur-dashboard && electron-rebuild && node -e \"if(process.platform==='darwin')require('child_process').execSync('find node_modules -name *.node -exec codesign --force --sign - {} +',{stdio:'inherit'})\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prong-horn/syntaur-app.git"
  },
  "dependencies": {
    "syntaur": "0.6.0",
    "update-electron-app": "^3.0.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-dmg": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@electron-forge/shared-types": "^7.6.0",
    "@electron/rebuild": "^3.7.0",
    "electron": "^34.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "author": "Prong Horn",
  "engines": {
    "node": ">=20.0.0"
  }
}
